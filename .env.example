# ==========================================
# ServiFlow Production Deployment Config
# ==========================================

# --------------------------
# Frontend Engine (.env)
# --------------------------
# Replace with your Firebase Project Configuration Dashboard outputs
VITE_FIREBASE_API_KEY="your_api_key_here"
VITE_FIREBASE_AUTH_DOMAIN="serviflow-XXXX.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="serviflow-XXXX"
VITE_FIREBASE_STORAGE_BUCKET="serviflow-XXXX.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789012"
VITE_FIREBASE_APP_ID="1:123456789012:web:abcdef1234567890"

# Target backend API node cluster
VITE_API_URL="http://localhost:5000/api" # Use https://yourdomain.com/api in production

# --------------------------
# Backend Node.js Server (.env)
# --------------------------
# Replace with Firebase Admin SDK Service Account keys if upgrading to strictly authorized admin writes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@serviflow-XXXX.iam.gserviceaccount.com"

PORT=5000
NODE_ENV="production"
