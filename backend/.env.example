## ServiFlow Backend (.env)
## Copy to `.env` for local development.
## For Render deployment, set these in Render -> Environment instead (do NOT commit secrets).

# Server
PORT=5000

# Firebase Admin SDK (choose ONE method)
# 1) Raw JSON (recommended on Render)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# 2) Base64 encoded JSON (optional)
# FIREBASE_SERVICE_ACCOUNT_B64=

# 3) Local file path (optional; local dev only)
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Fallback (only used when no service account is provided)
FIREBASE_PROJECT_ID=servicebookschedule

# Optional: CORS (if you later restrict origins in code)
# CORS_ORIGIN=http://localhost:5173
