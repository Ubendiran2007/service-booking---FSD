{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system (Admin, Customer, or Worker).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer", "worker"] },
        "status": { "type": "string", "enum": ["pending", "approved", "active"] },
        "profile": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "location": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            },
            "category": { "type": "string", "description": "For workers: electrician, plumber, etc." },
            "rating": { "type": "number", "default": 0 },
            "totalReviews": { "type": "number", "default": 0 }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Represents a service booking request.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "workerId": { "type": "string" },
        "serviceType": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed", "cancelled"] },
        "payment": {
          "type": "object",
          "properties": {
            "amount": { "type": "number" },
            "status": { "type": "string", "enum": ["pending", "paid"] }
          }
        },
        "feedback": {
          "type": "object",
          "properties": {
            "rating": { "type": "number" },
            "comment": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "workerId", "serviceType", "date", "time", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Service booking records."
    }
  }
}
